# Sanity CMS — copy to .env.local and fill in your values.
# Get these from https://www.sanity.io/manage after creating a project.
# The site builds and renders WITHOUT these (it falls back to local content);
# they are only required to use the /studio editor and pull CMS content.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
