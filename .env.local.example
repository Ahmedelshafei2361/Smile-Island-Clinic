# ─────────────────────────────────────────────────────────────────────────────
# Smile Island Dental Clinic — environment variables
# Copy this file to `.env.local` (local dev) or set these in the VPS `.env`
# (production). Never commit real values — `.env.local` / `.env` are git-ignored.
#
# NEXT_PUBLIC_*  → PUBLIC. Inlined into the browser bundle. Never put secrets here.
# (no prefix)    → SECRET. Server-only. Never exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── Sanity CMS (PUBLIC) ──────────────────────────────────────────────────────
# From https://www.sanity.io/manage. The site still builds/renders without these
# (it falls back to local content), but CMS content + /studio need them.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# ── Site origin (PUBLIC) ─────────────────────────────────────────────────────
# Used for canonical URLs, Open Graph, robots.txt, and sitemap.xml.
# MUST be the production domain in production, no trailing slash.
# Defaults to http://localhost:3000 when unset (dev only).
NEXT_PUBLIC_SITE_URL=https://smileislandclinic.com

# ── Google Tag Manager (PUBLIC) ──────────────────────────────────────────────
# GTM container id. When unset, GTM never loads. GTM is consent-gated and is the
# single entry point for GA4 / Meta Pixel / Microsoft Clarity — add those INSIDE
# GTM, never directly in code.
NEXT_PUBLIC_GTM_ID=

# ── Sanity read token (SECRET — server-only) ─────────────────────────────────
# REQUIRED in production: this dataset's public role cannot read `service`
# documents, so without this token the site falls back to local data for all
# services. Create a "Viewer" token in Sanity → API → Tokens. NEVER prefix with
# NEXT_PUBLIC_. The build does not depend on it.
SANITY_API_READ_TOKEN=

# ── Sanity write token (SECRET — server-only, optional) ──────────────────────
# Only needed to run `npm run seed:services` (one-off content seeding).
# NOT needed at runtime. Do not deploy this to the running app unless seeding.
SANITY_API_WRITE_TOKEN=
